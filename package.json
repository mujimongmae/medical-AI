{
  "name": "community-emergency-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "마을 공동체 기반 응급대응 앱 (강원 독거노인) — 데모: 맥북 브로커 + 단일 웹앱(역할 모드)",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently -n app,server -c cyan,magenta \"npm:dev\" \"npm:server\"",
    "build": "vite build",
    "sync:ios": "npm run build && npx cap copy ios",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
