{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(git *)",
      "Bash(supabase *)",
      "Edit(app/**)",
      "Edit(components/**)",
      "Edit(lib/**)",
      "Edit(supabase/**)",
      "Write(app/**)",
      "Write(components/**)",
      "Write(lib/**)",
      "Write(supabase/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/patient-data/**)",
      "Read(**/*real*patient*)",
      "Bash(rm -rf /)",
      "Write(.git/**)"
    ],
    "ask": [
      "Bash(vercel *)",
      "Bash(supabase db push*)",
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/spec-first-reminder.sh \"${tool_input.file_path}\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write ${tool_input.file_path} 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
